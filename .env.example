PORT=5000
MONGODB_URI=mongodb://localhost:27017/karya
JWT_SECRET=replace-me
PUBLIC_BACKEND_URL=https://api-dev.nasdiya.com
RESEND_API_KEY=replace-me
RESEND_FROM=Karya <no-reply@example.com>

# Cloudflare R2 object storage
# Required to store uploads in R2 instead of local disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional:
# If set, uploaded files will use this public base URL directly, for example:
# R2_PUBLIC_BASE_URL=https://media.nasdiya.com
# If empty, the app will keep serving files through /uploads/<key>.
R2_PUBLIC_BASE_URL=

# Optional key prefix inside the bucket. Default: media
R2_KEY_PREFIX=media

# Website payment gateway display config
# Set these when you connect a real online gateway provider.
WEBSITE_GATEWAY_PROVIDER=
WEBSITE_GATEWAY_PUBLIC_KEY=

# SMTP receipt email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Default admin bootstrap (no registration required)
# The backend will auto-create/sync this admin account on server start.
ADMIN_EMAIL=admin@karya.local
ADMIN_PASSWORD=Admin@123
ADMIN_FIRST_NAME=Karya
ADMIN_LAST_NAME=Admin

# Social auth provider credentials
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
FACEBOOK_CLIENT_ID=replace-me
FACEBOOK_CLIENT_SECRET=replace-me
LINKEDIN_CLIENT_ID=replace-me
LINKEDIN_CLIENT_SECRET=replace-me
TWITTER_CLIENT_ID=replace-me
TWITTER_CLIENT_SECRET=replace-me
